---
// CTA.astro
---

<section id="contact" class="py-16 md:py-24 bg-white overflow-hidden relative">
  <!-- Decorative background -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-20 -left-20 w-80 h-80 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-20 -right-20 w-80 h-80 bg-secondary/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-5 sm:px-6">
    <!-- Top CTA Banner -->
    <div class="bg-dark rounded-3xl overflow-hidden relative scroll-reveal">
      <!-- Background gradient -->
      <div class="absolute inset-0 bg-gradient-to-br from-dark via-secondary/80 to-dark opacity-90"></div>
      <!-- Decorative grid -->
      <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(white 1px, transparent 1px); background-size: 30px 30px;"></div>
      <!-- Decorative circles -->
      <div class="absolute -top-20 -right-20 w-64 h-64 bg-primary/10 rounded-full blur-2xl"></div>
      <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-accent/10 rounded-full blur-2xl"></div>

      <div class="relative z-10 px-5 sm:px-8 md:px-16 py-10 sm:py-14 text-center">
        <div class="inline-flex items-center gap-2 bg-primary/20 border border-primary/30 text-primary text-xs sm:text-sm font-semibold px-3 sm:px-4 py-2 rounded-full mb-5">
          <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
          Konsultasi Terbuka Setiap Hari
        </div>

        <h2 class="text-2xl sm:text-3xl md:text-5xl font-bold text-white mb-3 leading-tight">
          Siap Mewujudkan
          <span class="gradient-text"> Proyek Impian</span> Anda?
        </h2>
        <p class="text-sm sm:text-base md:text-lg text-gray-300 mb-6 sm:mb-10 max-w-2xl mx-auto">
          Diskusikan kebutuhan Anda bersama arsitek profesional kami sekarang. 
          Konsultasi pertama <strong class="text-white">100% gratis</strong> dan tanpa kewajiban.
        </p>

        <!-- Contact form -->
        <div class="max-w-2xl mx-auto bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-4 sm:p-6 md:p-8 text-left">
          <h3 class="text-white font-bold text-lg mb-6 text-center">Jadwalkan Konsultasi Gratis</h3>
          <form id="consultation-form" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-300 mb-2">Nama Lengkap</label>
                <input 
                  id="name"
                  type="text" 
                  placeholder="Masukkan nama Anda"
                  class="w-full bg-white/10 border border-white/20 text-white placeholder-gray-400 px-4 py-3 rounded-xl focus:outline-none focus:border-primary focus:bg-white/15 transition-all text-sm"
                  required
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-300 mb-2">Nomor WhatsApp</label>
                <input 
                  id="phone"
                  type="tel" 
                  placeholder="+62 812 xxxx xxxx"
                  class="w-full bg-white/10 border border-white/20 text-white placeholder-gray-400 px-4 py-3 rounded-xl focus:outline-none focus:border-primary focus:bg-white/15 transition-all text-sm"
                  required
                />
              </div>
            </div>
            <div>
              <label for="project-type" class="block text-sm font-medium text-gray-300 mb-2">Jenis Proyek</label>
              <select 
                id="project-type"
                class="w-full bg-white/10 border border-white/20 text-gray-300 px-4 py-3 rounded-xl focus:outline-none focus:border-primary transition-all text-sm appearance-none"
                required
              >
                <option value="" class="bg-dark">Pilih jenis proyek...</option>
                <option value="rumah" class="bg-dark">Desain Rumah Tinggal</option>
                <option value="komersial" class="bg-dark">Bangunan Komersial</option>
                <option value="gambar-kerja" class="bg-dark">Gambar Kerja & Perizinan</option>
                <option value="konsultasi" class="bg-dark">Konsultasi Umum</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-300 mb-2">Ceritakan Proyek Anda</label>
              <textarea 
                id="message"
                rows="3"
                placeholder="Jelaskan secara singkat kebutuhan dan ekspektasi Anda..."
                class="w-full bg-white/10 border border-white/20 text-white placeholder-gray-400 px-4 py-3 rounded-xl focus:outline-none focus:border-primary focus:bg-white/15 transition-all text-sm resize-none"
              ></textarea>
            </div>
            <button 
              type="submit"
              id="submit-consultation-btn"
              class="w-full bg-accent text-dark font-bold py-4 rounded-xl hover:bg-yellow-400 shadow-lg shadow-amber-500/30 transition-all duration-300 hover:-translate-y-0.5 flex items-center justify-center gap-2 group"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
              Jadwalkan Konsultasi Sekarang
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </button>
            <p class="text-center text-xs text-gray-400">
              🔒 Data Anda aman. Kami tidak akan membagikan informasi Anda kepada pihak ketiga.
            </p>
          </form>
        </div>

        <!-- Contact options -->
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 sm:gap-6 mt-6 sm:mt-8">
          <a 
            href="https://wa.me/6281234567890" 
            target="_blank"
            rel="noopener noreferrer"
            id="whatsapp-btn"
            class="inline-flex items-center justify-center gap-3 bg-[#25D366] text-white font-semibold px-6 py-3 rounded-xl hover:bg-[#1da85a] transition-all duration-300 hover:-translate-y-0.5 shadow-lg text-sm sm:text-base"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Chat via WhatsApp
          </a>
          <a 
            href="mailto:hello@axionovagroup.com"
            id="email-btn"
            class="inline-flex items-center justify-center gap-3 bg-white/15 border border-white/30 text-white font-semibold px-6 py-3 rounded-xl hover:bg-white/25 transition-all duration-300 text-sm sm:text-base"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            hello@axionovagroup.com
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('consultation-form');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = (document.getElementById('name') as HTMLInputElement)?.value;
      const phone = (document.getElementById('phone') as HTMLInputElement)?.value;
      const projectType = (document.getElementById('project-type') as HTMLSelectElement)?.value;
      const message = (document.getElementById('message') as HTMLTextAreaElement)?.value;
      
      const waText = encodeURIComponent(
        `Halo Axionova Group! Saya ${name} ingin konsultasi mengenai proyek ${projectType}.\n\nPesan: ${message}\n\nNo. WA: ${phone}`
      );
      window.open(`https://wa.me/6281234567890?text=${waText}`, '_blank');
    });
  </script>
</section>
