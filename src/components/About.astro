---
// About.astro
---

<section id="about" class="py-16 md:py-24 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-5 sm:px-6">
    <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
      
      <!-- Left: Image Grid -->
      <div class="relative scroll-reveal scroll-reveal-left mt-6 md:mt-0">
        <div class="grid grid-cols-2 gap-3 sm:gap-4">
          <div class="col-span-2">
            <img 
              src="/about-team.png" 
              alt="Tim arsitek profesional Axionova Group"
              class="w-full h-52 sm:h-64 object-cover rounded-2xl shadow-xl"
              loading="lazy"
            />
          </div>
          <!-- Stats cards below image -->
          <div class="bg-gradient-to-br from-primary to-primary-dark rounded-2xl p-4 sm:p-5 text-white shadow-lg">
            <div class="text-2xl sm:text-3xl font-bold mb-1">10+</div>
            <p class="text-sm text-orange-100 font-medium">Tahun Pengalaman</p>
            <div class="mt-3 w-8 h-1 bg-white/40 rounded-full"></div>
          </div>
          <div class="bg-gradient-to-br from-dark to-secondary rounded-2xl p-4 sm:p-5 text-white shadow-lg">
            <div class="text-2xl sm:text-3xl font-bold mb-1">250+</div>
            <p class="text-sm text-gray-300 font-medium">Proyek Berhasil</p>
            <div class="mt-3 w-8 h-1 bg-white/40 rounded-full"></div>
          </div>
        </div>

        <!-- Decorative blob -->
        <div class="absolute -z-10 -left-10 top-1/2 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
        
        <!-- IAI Badge — repositioned for mobile -->
        <div class="absolute -top-3 right-2 sm:-top-4 sm:-right-4 bg-white border-2 border-accent rounded-2xl p-2.5 sm:p-3 shadow-xl z-10">
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 sm:w-8 sm:h-8 bg-accent/20 rounded-lg flex items-center justify-center">
              <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-bold text-dark">IAI Certified</p>
              <p class="text-xs text-gray-400">Tersertifikasi</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="scroll-reveal">
        <!-- Section label -->
        <div class="inline-flex items-center gap-2 text-primary text-sm font-semibold mb-4">
          <div class="w-8 h-0.5 bg-primary"></div>
          Tentang Kami
        </div>

        <h2 class="text-2xl sm:text-3xl md:text-5xl font-bold text-dark leading-tight mb-5">
          Membangun dengan
          <span class="gradient-text"> Keahlian & Integritas</span>
        </h2>

        <p class="text-base sm:text-lg text-gray-600 leading-relaxed mb-6">
          <strong class="text-dark">Axionova Group</strong> adalah firma arsitektur terpercaya yang mengutamakan kualitas desain dan kepuasan klien. Kami telah menangani ratusan proyek dengan pendekatan modern, efisien, dan berorientasi pada nilai investasi jangka panjang.
        </p>

        <!-- Key points -->
        <div class="space-y-3 mb-8">
          {[
            { icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z", text: "Berpengalaman lebih dari 10 tahun di industri arsitektur", highlight: "10 Tahun" },
            { icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z", text: "Tim profesional bersertifikasi IAI & pengalaman internasional", highlight: "IAI Certified" },
            { icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4", text: "Ratusan proyek residensial dan komersial berhasil diselesaikan", highlight: "250+ Proyek" },
          ].map((item) => (
            <div class="flex items-start gap-3 p-3 sm:p-4 rounded-xl hover:bg-gray-50 transition-colors duration-200 group">
              <div class="w-9 h-9 sm:w-10 sm:h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
                </svg>
              </div>
              <div>
                <span class="text-xs font-bold text-primary uppercase tracking-wider">{item.highlight}</span>
                <p class="text-gray-700 text-sm mt-0.5 leading-relaxed">{item.text}</p>
              </div>
            </div>
          ))}
        </div>

        <a 
          href="#contact"
          id="about-cta-btn"
          class="inline-flex items-center gap-2 bg-dark text-white font-semibold px-6 py-3.5 rounded-xl hover:bg-secondary shadow-lg transition-all duration-300 hover:-translate-y-0.5 group text-sm sm:text-base"
        >
          Konsultasi dengan Tim Kami
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
