---
// Hero.astro
---

<section id="hero" class="relative min-h-screen bg-gray-50 overflow-hidden flex items-center">
  <!-- Background decorative elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] bg-primary/8 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-[500px] h-[500px] bg-secondary/8 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-accent/5 rounded-full blur-3xl"></div>
  </div>

  <!-- Grid pattern -->
  <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(#5f668c22 1px, transparent 1px); background-size: 40px 40px;"></div>

  <div class="relative max-w-7xl mx-auto px-6 py-32 pt-40">
    <div class="grid md:grid-cols-2 items-center gap-16">
      
      <!-- Left Content -->
      <div>
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-primary/10 border border-primary/20 text-primary text-sm font-semibold px-4 py-2 rounded-full mb-6">
          <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
          Konsultasi Pertama 100% Gratis
        </div>

        <!-- Headline -->
        <h1 class="text-4xl md:text-6xl font-bold leading-[1.1] text-dark mb-6">
          Wujudkan Hunian
          <span class="gradient-text block">Impian Anda</span>
          dengan Arsitek Profesional
        </h1>

        <!-- Subheadline -->
        <p class="text-lg text-gray-600 leading-relaxed mb-8 max-w-xl">
          Kami membantu Anda merancang ruang yang estetis, fungsional, dan 
          <strong class="text-dark">bernilai investasi tinggi</strong> — dari konsep hingga bangunan jadi.
        </p>

        <!-- Stats row -->
        <div class="flex gap-8 mb-10">
          <div>
            <div class="text-3xl font-bold text-dark flex items-end gap-1">
              <span data-target="10">0</span>
              <span class="text-primary">+</span>
            </div>
            <p class="text-xs text-gray-500 font-medium mt-0.5">Tahun Pengalaman</p>
          </div>
          <div class="w-px bg-gray-200"></div>
          <div>
            <div class="text-3xl font-bold text-dark flex items-end gap-1">
              <span data-target="250">0</span>
              <span class="text-primary">+</span>
            </div>
            <p class="text-xs text-gray-500 font-medium mt-0.5">Proyek Selesai</p>
          </div>
          <div class="w-px bg-gray-200"></div>
          <div>
            <div class="text-3xl font-bold text-dark flex items-end gap-1">
              <span data-target="98">0</span>
              <span class="text-primary">%</span>
            </div>
            <p class="text-xs text-gray-500 font-medium mt-0.5">Klien Puas</p>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a 
            href="#contact" 
            id="hero-cta-primary"
            class="inline-flex items-center justify-center gap-2 bg-dark text-white font-semibold px-8 py-4 rounded-xl hover:bg-secondary shadow-xl shadow-dark/20 hover:shadow-secondary/30 transition-all duration-300 hover:-translate-y-1 group"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            Konsultasi Gratis Sekarang
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a 
            href="#portfolio"
            id="hero-cta-secondary"
            class="inline-flex items-center justify-center gap-2 border-2 border-gray-300 text-dark font-semibold px-8 py-4 rounded-xl hover:border-primary hover:text-primary hover:bg-orange-50 transition-all duration-300 group"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Lihat Portofolio
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="mt-10 flex items-center gap-4">
          <div class="flex -space-x-2">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-orange-400 to-orange-600 border-2 border-white flex items-center justify-center text-white text-xs font-bold">A</div>
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 border-2 border-white flex items-center justify-center text-white text-xs font-bold">B</div>
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-400 to-green-600 border-2 border-white flex items-center justify-center text-white text-xs font-bold">C</div>
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-400 to-purple-600 border-2 border-white flex items-center justify-center text-white text-xs font-bold">D</div>
          </div>
          <div>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <p class="text-xs text-gray-500 mt-0.5">250+ klien memberikan bintang 5</p>
          </div>
        </div>
      </div>

      <!-- Right: Hero Image -->
      <div class="relative hidden md:block">
        <!-- Main image card -->
        <div class="relative z-10 rounded-3xl overflow-hidden shadow-2xl float-anim">
          <img 
            src="/hero-bg.png" 
            alt="Proyek arsitektur modern Axionova Group"
            class="w-full h-[520px] object-cover"
            loading="eager"
          />
          <!-- Overlay gradient -->
          <div class="absolute inset-0 bg-gradient-to-t from-dark/30 to-transparent"></div>
          
          <!-- Floating badge on image -->
          <div class="absolute bottom-6 left-6 right-6 bg-white/90 backdrop-blur-md rounded-2xl p-4 shadow-xl">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-dark">Proyek Terbaru Selesai</p>
                <p class="text-xs text-gray-500">Villa Modern — Jakarta Selatan • 2024</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating stats card -->
        <div class="absolute -top-6 -right-6 bg-white rounded-2xl shadow-xl p-4 z-20 border border-gray-100">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <p class="text-lg font-bold text-dark">IAI</p>
              <p class="text-xs text-gray-500">Bersertifikasi</p>
            </div>
          </div>
        </div>

        <!-- Decorative elements -->
        <div class="absolute -bottom-8 -left-8 w-32 h-32 bg-primary/10 rounded-full blur-xl"></div>
        <div class="absolute -top-10 left-10 w-20 h-20 bg-accent/20 rounded-full blur-lg"></div>
      </div>
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 60L60 50C120 40 240 20 360 15C480 10 600 20 720 25C840 30 960 30 1080 25C1200 20 1320 10 1380 5L1440 0V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>
</section>
