---
// Footer.astro
---

<footer class="bg-dark text-white overflow-hidden relative">
  <!-- Top wave -->
  <div class="w-full overflow-hidden leading-none -mb-1">
    <svg viewBox="0 0 1440 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 0L60 6.67C120 13.3 240 26.7 360 30C480 33.3 600 26.7 720 23.3C840 20 960 20 1080 23.3C1200 26.7 1320 33.3 1380 36.7L1440 40V0H1380C1320 0 1200 0 1080 0C960 0 840 0 720 0C600 0 480 0 360 0C240 0 120 0 60 0H0Z" fill="#1E293B"/>
    </svg>
  </div>

  <!-- Decorative blobs -->
  <div class="absolute top-20 left-20 w-72 h-72 bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-10 right-20 w-72 h-72 bg-secondary/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6 pt-12 pb-8">
    <div class="grid md:grid-cols-3 gap-10 mb-12">
      
      <!-- Brand column -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary to-accent flex items-center justify-center shadow-lg">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <div>
            <span class="font-bold text-xl tracking-tight">Axionova</span>
            <span class="font-bold text-xl text-primary tracking-tight"> Group</span>
          </div>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-5">
          Desain yang membangun masa depan. Firma arsitektur profesional dengan pengalaman lebih dari 10 tahun di Indonesia.
        </p>

        <!-- Social links -->
        <div class="flex gap-3">
          {[
            { name: "Instagram", icon: "M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01M6.5 19.5h11a2 2 0 002-2v-11a2 2 0 00-2-2h-11a2 2 0 00-2 2v11a2 2 0 002 2z", href: "#" },
            { name: "LinkedIn", icon: "M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z", href: "#" },
            { name: "YouTube", icon: "M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z", href: "#" },
          ].map(social => (
            <a 
              href={social.href}
              aria-label={social.name}
              class="w-9 h-9 bg-white/10 hover:bg-primary rounded-xl flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5"
            >
              <svg class="w-4 h-4 text-gray-400 hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-bold text-white mb-5 text-sm uppercase tracking-wider">Navigasi</h4>
        <ul class="space-y-3">
          {[
            { label: "Tentang Kami", href: "#about" },
            { label: "Layanan", href: "#services" },
            { label: "Portofolio", href: "#portfolio" },
            { label: "Proses Kerja", href: "#process" },
            { label: "Testimoni", href: "#testimonials" },
            { label: "Konsultasi Gratis", href: "#contact" },
          ].map(link => (
            <li>
              <a 
                href={link.href}
                class="text-gray-400 hover:text-primary text-sm transition-colors duration-200 flex items-center gap-2 group"
              >
                <span class="w-0 group-hover:w-4 h-0.5 bg-primary transition-all duration-300 inline-block"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="font-bold text-white mb-5 text-sm uppercase tracking-wider">Hubungi Kami</h4>
        <div class="space-y-4">
          <a href="https://wa.me/6281234567890" target="_blank" rel="noopener noreferrer"
             class="flex items-start gap-3 group">
            <div class="w-9 h-9 bg-[#25D366]/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-[#25D366]/20 transition-colors">
              <svg class="w-4 h-4 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-500 font-medium">WhatsApp</p>
              <p class="text-gray-300 text-sm group-hover:text-primary transition-colors">+62 812 3456 7890</p>
            </div>
          </a>

          <a href="mailto:hello@axionovagroup.com" class="flex items-start gap-3 group">
            <div class="w-9 h-9 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
              <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-500 font-medium">Email</p>
              <p class="text-gray-300 text-sm group-hover:text-primary transition-colors">hello@axionovagroup.com</p>
            </div>
          </a>

          <div class="flex items-start gap-3">
            <div class="w-9 h-9 bg-secondary/20 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-500 font-medium">Lokasi</p>
              <p class="text-gray-300 text-sm">Jakarta, Bandung, Surabaya</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-sm text-center md:text-left">
        © 2024 <span class="text-primary font-medium">Axionova Group</span>. Hak cipta dilindungi. 
        Arkana Studio Architect — <em>Desain yang membangun masa depan.</em>
      </p>
      <div class="flex items-center gap-4 text-xs text-gray-500">
        <a href="#" class="hover:text-primary transition-colors">Kebijakan Privasi</a>
        <span>•</span>
        <a href="#" class="hover:text-primary transition-colors">Syarat & Ketentuan</a>
      </div>
    </div>
  </div>
</footer>
