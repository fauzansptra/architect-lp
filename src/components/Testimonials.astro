---
// Testimonials.astro

const testimonials = [
  {
    name: "Budi Santoso",
    role: "Pemilik Villa Modern",
    location: "Jakarta Selatan",
    avatar: "BS",
    avatarColor: "from-orange-400 to-orange-600",
    rating: 5,
    text: "Axionova Group benar-benar memahami visi kami. Desain villa kami melebihi ekspektasi — estetis, fungsional, dan bernilai investasi tinggi. Tim mereka sangat profesional dan responsif sepanjang proses.",
    project: "Villa Tropis Modern",
  },
  {
    name: "Sari Wijaya",
    role: "CEO, Wijaya Property",
    location: "Bandung",
    avatar: "SW",
    avatarColor: "from-blue-400 to-blue-600",
    rating: 5,
    text: "Proyek gedung perkantoran kami selesai tepat waktu dan sesuai anggaran. Kualitas desainnya mendapat pujian dari para klien kami. Saya sudah mempercayakan 3 proyek kepada mereka.",
    project: "Gedung Perkantoran SOHO",
  },
  {
    name: "Ahmad Fauzi",
    role: "Developer Properti",
    location: "Surabaya",
    avatar: "AF",
    avatarColor: "from-purple-400 to-purple-600",
    rating: 5,
    text: "Proses yang transparan dan komunikasi yang sangat baik. Dari konsep sampai gambar kerja, semuanya detail dan akurat. Perizinan pun beres dengan bantuan tim mereka. Highly recommended!",
    project: "Perumahan Cluster Premium",
  },
];
---

<section id="testimonials" class="py-16 md:py-24 bg-dark overflow-hidden relative">
  <!-- Background decorations -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-0 left-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-secondary/10 rounded-full blur-3xl"></div>
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(white 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-5 sm:px-6">
    
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-10 md:mb-16 scroll-reveal">
      <div class="inline-flex items-center gap-2 text-primary text-sm font-semibold mb-4">
        <div class="w-8 h-0.5 bg-primary"></div>
        Testimoni Klien
        <div class="w-8 h-0.5 bg-primary"></div>
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-bold text-white leading-tight mb-3">
        Apa Kata
        <span class="gradient-text"> Klien Kami</span>
      </h2>
      <p class="text-sm sm:text-base md:text-lg text-gray-400">
        Kepercayaan klien adalah aset terbesar kami. Simak pengalaman nyata mereka bersama Axionova Group.
      </p>
    </div>

    <!-- Testimonial Cards -->
    <div class="grid md:grid-cols-3 gap-4 md:gap-6">
      {testimonials.map((t, index) => (
        <div class={`scroll-reveal delay-${(index + 1) * 100} group bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-5 sm:p-7 hover:bg-white/10 hover:border-primary/30 transition-all duration-500 hover:-translate-y-2`}>
          <!-- Rating -->
          <div class="flex items-center gap-1 mb-4">
            {Array.from({length: t.rating}).map(() => (
              <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <div class="mb-4 relative">
            <svg class="w-8 h-8 text-primary/30 absolute -top-2 -left-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <p class="text-gray-300 text-sm leading-relaxed pl-6">{t.text}</p>
          </div>

          <!-- Project tag -->
          <div class="inline-flex items-center gap-1.5 bg-primary/10 border border-primary/20 text-primary text-xs font-medium px-3 py-1 rounded-full mb-5">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5" />
            </svg>
            {t.project}
          </div>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-white/10">
            <div class={`w-10 h-10 rounded-full bg-gradient-to-br ${t.avatarColor} flex items-center justify-center text-white text-sm font-bold flex-shrink-0`}>
              {t.avatar}
            </div>
            <div>
              <p class="font-semibold text-white text-sm">{t.name}</p>
              <p class="text-xs text-gray-400">{t.role} • {t.location}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom stats -->
    <div class="mt-8 md:mt-16 grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 scroll-reveal">
      {[
        { value: "250+", label: "Proyek Selesai", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16" },
        { value: "98%", label: "Klien Puas", icon: "M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
        { value: "10+", label: "Tahun Berpengalaman", icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
        { value: "15+", label: "Kota di Indonesia", icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" },
      ].map((stat) => (
        <div class="text-center p-4 sm:p-6 bg-white/5 border border-white/10 rounded-2xl hover:bg-white/10 transition-colors">
          <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={stat.icon} />
            </svg>
          </div>
          <div class="text-2xl sm:text-3xl font-bold text-white mb-1">{stat.value}</div>
          <p class="text-gray-400 text-sm">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
